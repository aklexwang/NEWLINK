# ── 서버 ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── DB (SQLite 로컬 / PostgreSQL 배포 시 아래 사용) ──
DATABASE_TYPE=sqlite
DATABASE_PATH=data/newlink.sqlite
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=newlink
# DATABASE_PASSWORD=your_password
# DATABASE_NAME=newlink

# ── 텔레그램 봇 (BotFather에서 발급) ─────────
# 형식: 1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ⚠ Git·스크린샷에 올리지 마세요. 유출 시 /revoke 후 재발급
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 관리자 텔레그램 숫자 ID (쉼표로 여러 명)
# @userinfobot 에게 /start 하면 id 확인 가능
TELEGRAM_ADMIN_IDS=123456789

# ── TON 결제 (Promoted 유료 노출, 미사용 시 더미값 유지) ──
# 1000000000 = 1 TON (나노톤 단위)
TELEGRAM_PAYMENT_PROVIDER_TOKEN=your_ton_provider_token
PROMOTION_PRICE_TON=1000000000
PROMOTION_DURATION_DAYS=7

# ── 개발 전용 (운영/미니앱에서는 반드시 false) ──
DEV_ADMIN_BYPASS=false

# ── 외부 브라우저 관리자 접속 키 (프론트 /admin?access=키) ──
ADMIN_ACCESS_KEY=your_admin_access_key_here
